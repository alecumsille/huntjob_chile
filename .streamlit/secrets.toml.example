# Secrets de HuntJob Chile para Streamlit Community Cloud / Render.
# Copiar este archivo a .streamlit/secrets.toml y rellenar los valores.
# NUNCA subas secrets.toml al repo — ya está en .gitignore.

# API key de Gemini (gratis en https://aistudio.google.com/apikey)
GEMINI_API_KEY = "tu-key-de-gemini-acá"

# API key de Groq, usada como respaldo automático si Gemini falla o
# supera su cuota (opcional, pero recomendada en producción).
GROQ_API_KEY = "tu-key-de-groq-acá"

# Anon Key del proyecto Supabase (Settings > API). Es pública por
# diseño — la seguridad real la da Row Level Security en Postgres
# (ver sql/schema.sql), nunca esta key. NUNCA uses la Service Role Key
# acá: la app no la necesita y filtrarla te da acceso total a la DB.
SUPABASE_ANON_KEY = "tu-anon-key-de-supabase-acá"

# Opcional — solo si cambias de proyecto de Supabase. Si no se define,
# usa el proyecto por defecto de Cumsille Systems Suite.
# SUPABASE_URL = "https://tu-proyecto.supabase.co"
