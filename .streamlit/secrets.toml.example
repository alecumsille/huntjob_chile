# Secrets de HuntJob Chile para Streamlit Community Cloud
# Copiar este archivo a .streamlit/secrets.toml y rellenar los valores.
# NUNCA subas secrets.toml al repo — ya está en .gitignore.

# API key de Gemini (gratis en https://aistudio.google.com/apikey)
GEMINI_API_KEY = "tu-key-de-gemini-acá"

# Contraseña para la app web pública.
# Sin esta variable, la app no pide clave (útil en local o desktop).
# En un despliegue público, ponla siempre para que nadie más acceda
# a tu perfil guardado en el servidor.
APP_PASSWORD = "una-clave-que-solo-sepas-vos"
